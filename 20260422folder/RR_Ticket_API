<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF 維修單號自動抓取工具</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; padding: 20px; background-color: #f5f7f9; color: #333; }
        .container { max-width: 800px; margin: 0 auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { color: #2c3e50; font-size: 24px; border-left: 5px solid #3498db; padding-left: 15px; }
        .upload-section { border: 2px dashed #3498db; padding: 40px; text-align: center; border-radius: 8px; margin: 20px 0; cursor: pointer; transition: 0.3s; }
        .upload-section:hover { background-color: #ebf5fb; }
        #fileInput { display: none; }
        .status { margin: 10px 0; font-weight: bold; color: #e67e22; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
        th { background-color: #f8f9fa; }
        .btn-group { margin-top: 20px; display: flex; gap: 10px; }
        button { padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer; font-size: 14px; transition: 0.2s; }
        .btn-copy { background-color: #3498db; color: white; }
        .btn-download { background-color: #27ae60; color: white; }
        button:hover { opacity: 0.8; }
        button:disabled { background-color: #ccc; cursor: not-allowed; }
    </style>
</head>
<body>

<div class="container">
    <h1>PDF 維修單號自動抓取工具</h1>
    <p>請上傳維修單 PDF 檔案，系統將自動提取「客戶維修單號」。</p>

    <div class="upload-section" onclick="document.getElementById('fileInput').click()">
        點擊此處或拖曳多個 PDF 檔案至此
        <input type="file" id="fileInput" accept="application/pdf" multiple>
    </div>

    <div id="status" class="status"></div>

    <div class="btn-group">
        <button id="copyBtn" class="btn-copy" disabled>複製單號列表</button>
        <button id="downloadBtn" class="btn-download" disabled>下載 CSV</button>
    </div>

    <table id="resultTable">
        <thead>
            <tr>
                <th>檔名</th>
                <th>客戶維修單號</th>
            </tr>
        </thead>
        <tbody>
            </tbody>
    </table>
</div>

<script>
    // 設定 PDF.js 工作 worker
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';

    const fileInput = document.getElementById('fileInput');
    const status = document.getElementById('status');
    const tbody = document.querySelector('#resultTable tbody');
    const copyBtn = document.getElementById('copyBtn');
    const downloadBtn = document.getElementById('downloadBtn');

    let results = [];

    fileInput.addEventListener('change', async (e) => {
        const files = e.target.files;
        if (files.length === 0) return;

        status.innerText = `正在初始化處理 ${files.length} 個檔案...`;
        tbody.innerHTML = '';
        results = [];
        
        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            status.innerText = `正在處理 (${i + 1}/${files.length}): ${file.name}`;
            
            try {
                const serialNumber = await extractSerialNumber(file);
                results.push({ fileName: file.name, sn: serialNumber || '未找到單號' });
                
                // 即時渲染表格
                const row = `<tr><td>${file.name}</td><td>${serialNumber || '<span style="color:red">未找到</span>'}</td></tr>`;
                tbody.insertAdjacentHTML('beforeend', row);
            } catch (error) {
                console.error(error);
                tbody.insertAdjacentHTML('beforeend', `<tr><td>${file.name}</td><td style="color:red">讀取失敗</td></tr>`);
            }
        }

        status.innerText = `處理完成！共計 ${files.length} 個檔案。`;
        copyBtn.disabled = false;
        downloadBtn.disabled = false;
    });

async function processFullPdf(file) {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument(arrayBuffer).promise;

    // 跑遍每一頁，不再只抓前三頁，也不需要手動拆分檔案
    for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        let text = await getPageText(page); // 嘗試抓取文字

        // 【自動 OCR 邏輯】
        if (text.trim().length < 5) { 
            // 如果沒文字，代表是圖片檔，啟動 OCR
            text = await performOCR(page); 
        }

        const sn = findRRNumber(text); // 用原本的正則表達式找 RR 號
        
        // 將「檔名 + 第幾頁 + 找到的單號」直接塞入結果表格
        addResultToTable(file.name, i, sn);
    }
}

    // 清理 PDF 常見亂碼空白
    fullText = fullText
        .replace(/\s+/g, ' ')
        .replace(/：/g, ':')
        .trim();

    /*
    終極版抓法（依優先順序）

    1. 客戶維修單號附近抓 RR號
    2. SR單號附近抓 RR號
    3. 全文抓 RR號
    4. 抓 RMA / 維修格式
    */

    const patterns = [

        // 客戶維修單號：TSC XXX-RR2603180068
        /客戶維修單號\s*:?\s*.*?(RR\d{8,})/i,

        // 維修單號：RR2603180068
        /維修單號\s*:?\s*(RR\d{8,})/i,

        // 單號：RR2603180068
        /單號\s*:?\s*(RR\d{8,})/i,

        // 任意位置 RR號（最泛用）
        /\b(RR\d{8,})\b/i,

        // 若有 RMA2603180068
        /\b(RMA\d{6,})\b/i,

        // 若有 REP2603180068
        /\b(REP\d{6,})\b/i
    ];

    for (const regex of patterns) {
        const match = fullText.match(regex);
        if (match) {
            return match[1] || match[0];
        }
    }

    return null;
}

    // 複製功能
    copyBtn.addEventListener('click', () => {
        const text = results.map(r => r.sn).join('\n');
        navigator.clipboard.writeText(text).then(() => alert('已複製所有單號到剪貼簿'));
    });

    // 下載 CSV 功能
    downloadBtn.addEventListener('click', () => {
        let csvContent = "data:text/csv;charset=utf-8,檔名,客戶維修單號\n";
        results.forEach(r => {
            csvContent += `${r.fileName},${r.sn}\n`;
        });
        const encodedUri = encodeURI(csvContent);
        const link = document.createElement("a");
        link.setAttribute("href", encodedUri);
        link.setAttribute("download", "維修單號抓取結果.csv");
        document.body.appendChild(link);
        link.click();
    });
</script>

</body>
</html>
